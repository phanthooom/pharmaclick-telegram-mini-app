# Shared
NODE_ENV=development

# Mini App / BFF
NEXT_PUBLIC_APP_NAME=PharmaClick Mini App
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBAPP_URL=http://localhost:3000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_DEBUG=true
API_SECRET_KEY=replace_me
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
POSTGRES_DB=pharmaclick
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pharmaclick

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# OTP / SMS
SMS_PROVIDER=playmobile
SMS_API_KEY=replace_me
SMS_SENDER=PharmaClick

# Storage
S3_ENDPOINT=replace_me
S3_ACCESS_KEY=replace_me
S3_SECRET_KEY=replace_me
S3_BUCKET=pharmaclick-media

# Admin
ADMIN_APP_PORT=3001
